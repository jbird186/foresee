#pub macro !u8 {store_u8}
#pub macro @u8 {fetch_u8}
#pub macro @@u8 {fetch_u8 fetch_u8}
#pub macro @@@u8 {fetch_u8 fetch_u8 fetch_u8}
#pub macro @@@@u8 {fetch_u8 fetch_u8 fetch_u8 fetch_u8}
#pub macro @u8++ {dup fetch_u8 dup 1+ rot store_u8}
#pub macro ++@u8 {dup fetch_u8 1+ dup rot store_u8}
#pub macro @u8-- {dup fetch_u8 dup 1- rot store_u8}
#pub macro --@u8 {dup fetch_u8 1- dup rot store_u8}

#pub macro ! {!i64}
#pub macro @ {@i64}
#pub macro @@ {@@i64}
#pub macro @@@ {@@@i64}
#pub macro @@@@ {@@@@i64}
#pub macro @++ {@i64++}
#pub macro ++@ {++@i64}
#pub macro @-- {@i64--}
#pub macro --@ {--@i64}

#pub macro !c {!u8}
#pub macro @c {@u8}
#pub macro @@c {@@u8}
#pub macro @@@c {@@@u8}
#pub macro @@@@c {@@@@u8}
#pub macro @c++ {@u8++}
#pub macro ++@c {++@u8}
#pub macro @c-- {@u8--}
#pub macro --@c {--@u8}